# ─── GeoAttend Environment Variables ─────────────────────────────────────────
# Copy this file to .env.local and fill in your Supabase values
# Never commit .env.local to version control

# Supabase Project URL — from Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon/Public Key — from Project Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role Key — from Project Settings → API → service_role
# ⚠ KEEP THIS SECRET — only used in server actions, never in client code
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
